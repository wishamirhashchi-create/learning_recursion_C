#include <stdio.h>

typedef struct node{

   int x;
   struct node *next;
} NODE;


int insert_node(NODE *root, NODE *add);
void print_node(const NODE *root);


int main(){
  
   NODE root = {1, NULL};
   NODE add1 = {2, NULL};
   NODE add2 = {3, NULL};
   insert_node(&root , &add1);
   insert_node(&root , &add2);

   print_node(&root);
   return 0;

}


int insert_node(NODE *root, NODE *add){
   
      if (root == NULL || add == NULL) { // ensure both pointers are valid
        return 0;
      } 


      NODE * n = root; // using n to loop over the list of nodes
      while(n->next != NULL){ //looping over list until it reaches the end
         n = n->next;
      }
      n->next = add; /*a very important thing to remember is that the add->next MUST point to a valid address or NULL eventually, 
      if its uninitialized it would have an invalid address and dereferencing would lead to a crash or infinite loop or undefined behaviour, overall its bad*/
      return 1;

}



void print_node(const NODE *root){

    const NODE *n = root; 

    while (n != NULL){
        printf("%i\n", n->x);
        n = n->next;
    }
}
